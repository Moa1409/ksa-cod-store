# Public site config
NEXT_PUBLIC_SITE_URL=https://lamsaglow.shop
NEXT_PUBLIC_API_URL=https://api.lamsaglow.shop

# Pixels — PUBLIC IDs ONLY (never put CAPI tokens here)
NEXT_PUBLIC_ENABLE_PIXELS=true
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=

# Server-only (used by the Next /api/order proxy route). Not exposed to the browser.
# Local dev: point at docker compose backend (see repo docker-compose.yml).
API_URL=http://127.0.0.1:8000
# Production:
# API_URL=https://api.lamsaglow.shop

# Set to true ONLY for offline UI testing — orders will NOT be saved to the database.
# MOCK_ORDERS=true
